# Grafana
GF_ADMIN_USER=admin
GF_ADMIN_PASSWORD=ChangeMeStrongPassword123!

# MongoDB Exporter (special chars in password must be URL-encoded: = → %3D, * → %2A, @ → %40)
MONGODB_URI=mongodb://user:password@host:port/db?authSource=admin

# Redis Exporter (password plain text, không URL-encode)
REDIS_ADDR=redis://host:port
REDIS_PASSWORD=your_redis_password
