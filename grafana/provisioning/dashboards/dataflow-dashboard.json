{
  "uid": "data-flow",
  "title": "Data Flow",
  "tags": ["pipeline", "throughput"],
  "timezone": "browser",
  "schemaVersion": 39,
  "refresh": "30s",
  "time": { "from": "now-1h", "to": "now" },
  "panels": [

    {
      "id": 100,
      "title": "Layer 1–2: Gateway",
      "type": "row",
      "gridPos": { "x": 0, "y": 0, "w": 24, "h": 1 },
      "collapsed": false
    },

    {
      "id": 101,
      "title": "Số bài theo nền tảng (cửa sổ 5m)",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 1, "w": 12, "h": 8 },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "decimals": 0,
          "custom": { "lineWidth": 2, "fillOpacity": 12, "gradientMode": "opacity" }
        },
        "overrides": [
          { "matcher": { "id": "byName", "options": "youtube" },  "properties": [{ "id": "color", "value": { "fixedColor": "#FF0000", "mode": "fixed" } }] },
          { "matcher": { "id": "byName", "options": "facebook" }, "properties": [{ "id": "color", "value": { "fixedColor": "#1877F2", "mode": "fixed" } }] },
          { "matcher": { "id": "byName", "options": "tiktok" },   "properties": [{ "id": "color", "value": { "fixedColor": "#FE2C55", "mode": "fixed" } }] },
          { "matcher": { "id": "byName", "options": "telegram" }, "properties": [{ "id": "color", "value": { "fixedColor": "#26A5E4", "mode": "fixed" } }] },
          { "matcher": { "id": "byName", "options": "web" },      "properties": [{ "id": "color", "value": { "fixedColor": "#00CED1", "mode": "fixed" } }] },
          { "matcher": { "id": "byName", "options": "x" },        "properties": [{ "id": "color", "value": { "fixedColor": "#A0A0A0", "mode": "fixed" } }] }
        ]
      },
      "targets": [{
        "datasource": { "type": "prometheus" },
        "expr": "increase(gateway_posts_by_platform_total{platform!=\"news_page\"}[5m])",
        "legendFormat": "{{platform}}"
      }]
    },

    {
      "id": 102,
      "title": "Request Rate & Error Rate",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 1, "w": 12, "h": 8 },
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "custom": { "lineWidth": 2, "fillOpacity": 10, "gradientMode": "opacity" }
        },
        "overrides": [
          { "matcher": { "id": "byName", "options": "requests" },  "properties": [{ "id": "color", "value": { "fixedColor": "#73BF69", "mode": "fixed" } }] },
          { "matcher": { "id": "byName", "options": "errors 4xx" }, "properties": [{ "id": "color", "value": { "fixedColor": "#F2CC0C", "mode": "fixed" } }] },
          { "matcher": { "id": "byName", "options": "errors 5xx" }, "properties": [{ "id": "color", "value": { "fixedColor": "#F2495C", "mode": "fixed" } }] }
        ]
      },
      "targets": [
        { "datasource": { "type": "prometheus" }, "expr": "sum(rate(gateway_requests_total[5m]))", "legendFormat": "requests" },
        { "datasource": { "type": "prometheus" }, "expr": "sum(rate(gateway_http_errors_total{code=~\"4..\"}[5m]))", "legendFormat": "errors 4xx" },
        { "datasource": { "type": "prometheus" }, "expr": "sum(rate(gateway_http_errors_total{code=~\"5..\"}[5m]))", "legendFormat": "errors 5xx" }
      ]
    },

    {
      "id": 200,
      "title": "Layer 3: Kafka  ⭐⭐ (điểm tắc nghẽn số 1)",
      "type": "row",
      "gridPos": { "x": 0, "y": 9, "w": 24, "h": 1 },
      "collapsed": false
    },

    {
      "id": 201,
      "title": "Consumer Lag by Topic ⭐⭐",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 10, "w": 16, "h": 8 },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": { "lineWidth": 2, "fillOpacity": 15, "gradientMode": "opacity" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "#73BF69", "value": null },
              { "color": "#F2CC0C", "value": 1000 },
              { "color": "#F2495C", "value": 50000 }
            ]
          }
        }
      },
      "targets": [{
        "datasource": { "type": "prometheus" },
        "expr": "sum by (topic, consumergroup) (kafka_consumergroup_lag)",
        "legendFormat": "{{topic}} / {{consumergroup}}"
      }]
    },

    {
      "id": 202,
      "title": "Total Kafka Lag",
      "type": "stat",
      "gridPos": { "x": 16, "y": 10, "w": 8, "h": 4 },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background", "textMode": "auto", "graphMode": "area" },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "#73BF69", "value": null },
              { "color": "#F2CC0C", "value": 10000 },
              { "color": "#F2495C", "value": 50000 }
            ]
          }
        }
      },
      "targets": [{ "datasource": { "type": "prometheus" }, "expr": "sum(kafka_consumergroup_lag)", "legendFormat": "total lag" }]
    },

    {
      "id": 203,
      "title": "Lag Trend (tăng = consumer chậm)",
      "type": "stat",
      "gridPos": { "x": 16, "y": 14, "w": 8, "h": 4 },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background", "textMode": "auto", "graphMode": "none" },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "#73BF69", "value": null },
              { "color": "#F2CC0C", "value": 50 },
              { "color": "#F2495C", "value": 500 }
            ]
          }
        }
      },
      "targets": [{ "datasource": { "type": "prometheus" }, "expr": "deriv(sum(kafka_consumergroup_lag)[10m:1m])", "legendFormat": "lag/min", "instant": true }]
    },

    {
      "id": 204,
      "title": "Kafka Messages In/Out (rate)",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 18, "w": 24, "h": 6 },
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "custom": { "lineWidth": 2, "fillOpacity": 8, "gradientMode": "opacity" }
        },
        "overrides": [
          { "matcher": { "id": "byRegexp", "options": "in.*" },  "properties": [{ "id": "color", "value": { "fixedColor": "#73BF69", "mode": "fixed" } }] },
          { "matcher": { "id": "byRegexp", "options": "out.*" }, "properties": [{ "id": "color", "value": { "fixedColor": "#5794F2", "mode": "fixed" } }] }
        ]
      },
      "targets": [
        { "datasource": { "type": "prometheus" }, "expr": "sum by (topic) (rate(kafka_topic_partition_current_offset[5m]))", "legendFormat": "in {{topic}}" }
      ]
    },

    {
      "id": 300,
      "title": "Layer 4–6: MongoDB  ⭐⭐ (đã đau ở đây)",
      "type": "row",
      "gridPos": { "x": 0, "y": 24, "w": 24, "h": 1 },
      "collapsed": false
    },

    {
      "id": 301,
      "title": "MongoDB Status + Connections",
      "type": "stat",
      "gridPos": { "x": 0, "y": 25, "w": 8, "h": 4 },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background", "textMode": "value_and_name", "orientation": "vertical" },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "#73BF69", "value": null },
              { "color": "#F2CC0C", "value": 200 },
              { "color": "#F2495C", "value": 500 }
            ]
          }
        }
      },
      "targets": [
        { "datasource": { "type": "prometheus" }, "expr": "mongodb_connections{state=\"current\"}", "legendFormat": "connections", "instant": true },
        { "datasource": { "type": "prometheus" }, "expr": "mongodb_connections{state=\"available\"}", "legendFormat": "available", "instant": true }
      ]
    },

    {
      "id": 302,
      "title": "Connections % Used  ⭐ (gần max = pool sai)",
      "type": "gauge",
      "gridPos": { "x": 8, "y": 25, "w": 8, "h": 4 },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "orientation": "auto", "showThresholdMarkers": true },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0, "max": 100,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "#73BF69", "value": null },
              { "color": "#F2CC0C", "value": 60 },
              { "color": "#F2495C", "value": 80 }
            ]
          }
        }
      },
      "targets": [{
        "datasource": { "type": "prometheus" },
        "expr": "mongodb_connections{state=\"current\"} / (mongodb_connections{state=\"current\"} + mongodb_connections{state=\"available\"}) * 100",
        "legendFormat": "used %",
        "instant": true
      }]
    },

    {
      "id": 303,
      "title": "MongoDB Resident Memory",
      "type": "stat",
      "gridPos": { "x": 16, "y": 25, "w": 8, "h": 4 },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background", "textMode": "auto", "graphMode": "area" },
      "fieldConfig": {
        "defaults": {
          "unit": "decmbytes",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "#73BF69", "value": null },
              { "color": "#F2CC0C", "value": 1024 },
              { "color": "#F2495C", "value": 2048 }
            ]
          }
        }
      },
      "targets": [{ "datasource": { "type": "prometheus" }, "expr": "mongodb_memory{type=\"resident\"}", "legendFormat": "resident MB", "instant": true }]
    },

    {
      "id": 304,
      "title": "MongoDB Operations/sec",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 29, "w": 16, "h": 8 },
      "fieldConfig": {
        "defaults": {
          "unit": "ops",
          "custom": { "lineWidth": 2, "fillOpacity": 10, "gradientMode": "opacity" }
        },
        "overrides": [
          { "matcher": { "id": "byName", "options": "insert" },  "properties": [{ "id": "color", "value": { "fixedColor": "#73BF69", "mode": "fixed" } }] },
          { "matcher": { "id": "byName", "options": "query" },   "properties": [{ "id": "color", "value": { "fixedColor": "#5794F2", "mode": "fixed" } }] },
          { "matcher": { "id": "byName", "options": "update" },  "properties": [{ "id": "color", "value": { "fixedColor": "#F2CC0C", "mode": "fixed" } }] },
          { "matcher": { "id": "byName", "options": "delete" },  "properties": [{ "id": "color", "value": { "fixedColor": "#F2495C", "mode": "fixed" } }] },
          { "matcher": { "id": "byName", "options": "command" }, "properties": [{ "id": "color", "value": { "fixedColor": "#A0A0A0", "mode": "fixed" } }] }
        ]
      },
      "targets": [{ "datasource": { "type": "prometheus" }, "expr": "rate(mongodb_op_counters_total[5m])", "legendFormat": "{{type}}" }]
    },

    {
      "id": 305,
      "title": "MongoDB Connections Over Time",
      "type": "timeseries",
      "gridPos": { "x": 16, "y": 29, "w": 8, "h": 8 },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": { "lineWidth": 2, "fillOpacity": 15, "gradientMode": "opacity" }
        },
        "overrides": [
          { "matcher": { "id": "byName", "options": "current" },   "properties": [{ "id": "color", "value": { "fixedColor": "#F2CC0C", "mode": "fixed" } }] },
          { "matcher": { "id": "byName", "options": "available" }, "properties": [{ "id": "color", "value": { "fixedColor": "#73BF69", "mode": "fixed" } }] }
        ]
      },
      "targets": [
        { "datasource": { "type": "prometheus" }, "expr": "mongodb_connections{state=\"current\"}", "legendFormat": "current" },
        { "datasource": { "type": "prometheus" }, "expr": "mongodb_connections{state=\"available\"}", "legendFormat": "available" }
      ]
    },

    {
      "id": 400,
      "title": "Layer 7: Redis / BullMQ  ⭐ (điểm tắc nghẽn số 2)",
      "type": "row",
      "gridPos": { "x": 0, "y": 37, "w": 24, "h": 1 },
      "collapsed": false
    },

    {
      "id": 401,
      "title": "Redis Memory Used",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 38, "w": 12, "h": 8 },
      "fieldConfig": {
        "defaults": {
          "unit": "bytes",
          "custom": { "lineWidth": 2, "fillOpacity": 15, "gradientMode": "opacity" },
          "color": { "mode": "fixed", "fixedColor": "#FF7043" }
        }
      },
      "targets": [
        { "datasource": { "type": "prometheus" }, "expr": "redis_memory_used_bytes", "legendFormat": "used" },
        { "datasource": { "type": "prometheus" }, "expr": "redis_memory_max_bytes", "legendFormat": "maxmemory" }
      ]
    },

    {
      "id": 402,
      "title": "Redis Connections & Ops",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 38, "w": 12, "h": 8 },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": { "lineWidth": 2, "fillOpacity": 10, "gradientMode": "opacity" }
        },
        "overrides": [
          { "matcher": { "id": "byName", "options": "connected clients" }, "properties": [{ "id": "color", "value": { "fixedColor": "#5794F2", "mode": "fixed" } }] },
          { "matcher": { "id": "byName", "options": "ops/sec" },           "properties": [{ "id": "color", "value": { "fixedColor": "#73BF69", "mode": "fixed" } }] }
        ]
      },
      "targets": [
        { "datasource": { "type": "prometheus" }, "expr": "redis_connected_clients", "legendFormat": "connected clients" },
        { "datasource": { "type": "prometheus" }, "expr": "rate(redis_commands_processed_total[5m])", "legendFormat": "ops/sec" }
      ]
    }

  ]
}
