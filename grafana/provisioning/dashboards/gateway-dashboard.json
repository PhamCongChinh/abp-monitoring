{
  "uid": "gateway-overview",
  "title": "Gateway Overview",
  "tags": ["gateway", "golang"],
  "timezone": "browser",
  "schemaVersion": 39,
  "refresh": "30s",
  "time": { "from": "now/h", "to": "now" },
  "panels": [

    {
      "id": 500,
      "title": "Dữ liệu hôm nay",
      "type": "row",
      "gridPos": { "x": 0, "y": 0, "w": 24, "h": 1 },
      "collapsed": false
    },

    {
      "id": 501,
      "title": "Tổng bài hôm nay",
      "type": "stat",
      "gridPos": { "x": 0, "y": 1, "w": 4, "h": 8 },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background",
        "textMode": "auto",
        "graphMode": "none"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": { "mode": "fixed", "fixedColor": "#73BF69" }
        }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus" },
          "expr": "sum(increase(gateway_posts_by_platform_total[$__range]))",
          "legendFormat": "Tổng",
          "instant": true
        }
      ]
    },

    {
      "id": 502,
      "title": "Số bài theo nền tảng hôm nay",
      "type": "bargauge",
      "gridPos": { "x": 4, "y": 1, "w": 12, "h": 8 },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "orientation": "horizontal",
        "displayMode": "gradient",
        "valueMode": "color",
        "showUnfilled": true,
        "minVizWidth": 0,
        "minVizHeight": 10
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "min": 0,
          "thresholds": {
            "mode": "absolute",
            "steps": [{ "color": "blue", "value": null }]
          }
        },
        "overrides": [
          { "matcher": { "id": "byName", "options": "youtube" },  "properties": [{ "id": "color", "value": { "fixedColor": "#FF0000", "mode": "fixed" } }] },
          { "matcher": { "id": "byName", "options": "facebook" }, "properties": [{ "id": "color", "value": { "fixedColor": "#1877F2", "mode": "fixed" } }] },
          { "matcher": { "id": "byName", "options": "tiktok" },   "properties": [{ "id": "color", "value": { "fixedColor": "#FE2C55", "mode": "fixed" } }] },
          { "matcher": { "id": "byName", "options": "web" },      "properties": [{ "id": "color", "value": { "fixedColor": "#00CED1", "mode": "fixed" } }] },
          { "matcher": { "id": "byName", "options": "thread" },   "properties": [{ "id": "color", "value": { "fixedColor": "#A0A0A0", "mode": "fixed" } }] }
        ]
      },
      "targets": [
        {
          "datasource": { "type": "prometheus" },
          "expr": "sort_desc(increase(gateway_posts_by_platform_total{platform!~\"news_page|x|tt\"}[$__range]))",
          "legendFormat": "{{platform}}",
          "instant": true
        }
      ]
    },

    {
      "id": 503,
      "title": "Phân bổ nền tảng hôm nay",
      "type": "piechart",
      "gridPos": { "x": 16, "y": 1, "w": 8, "h": 8 },
      "options": {
        "pieType": "pie",
        "legend": { "displayMode": "hidden", "placement": "bottom", "values": [] },
        "tooltip": { "mode": "single" },
        "displayLabels": ["name", "percent"]
      },
      "fieldConfig": {
        "defaults": {},
        "overrides": [
          { "matcher": { "id": "byName", "options": "youtube" },  "properties": [{ "id": "color", "value": { "fixedColor": "#FF0000", "mode": "fixed" } }] },
          { "matcher": { "id": "byName", "options": "facebook" }, "properties": [{ "id": "color", "value": { "fixedColor": "#1877F2", "mode": "fixed" } }] },
          { "matcher": { "id": "byName", "options": "tiktok" },   "properties": [{ "id": "color", "value": { "fixedColor": "#FE2C55", "mode": "fixed" } }] },
          { "matcher": { "id": "byName", "options": "web" },      "properties": [{ "id": "color", "value": { "fixedColor": "#00CED1", "mode": "fixed" } }] },
          { "matcher": { "id": "byName", "options": "thread" },   "properties": [{ "id": "color", "value": { "fixedColor": "#A0A0A0", "mode": "fixed" } }] }
        ]
      },
      "targets": [
        {
          "datasource": { "type": "prometheus" },
          "expr": "increase(gateway_posts_by_platform_total{platform!~\"news_page|x|tt\"}[$__range])",
          "legendFormat": "{{platform}}",
          "instant": true
        }
      ]
    },

    {
      "id": 504,
      "title": "Tốc độ bài/giờ theo nền tảng",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 9, "w": 16, "h": 8 },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "decimals": 0,
          "custom": { "lineWidth": 2, "fillOpacity": 15, "gradientMode": "opacity" }
        },
        "overrides": [
          { "matcher": { "id": "byName", "options": "youtube" },  "properties": [{ "id": "color", "value": { "fixedColor": "#FF0000", "mode": "fixed" } }] },
          { "matcher": { "id": "byName", "options": "facebook" }, "properties": [{ "id": "color", "value": { "fixedColor": "#1877F2", "mode": "fixed" } }] },
          { "matcher": { "id": "byName", "options": "tiktok" },   "properties": [{ "id": "color", "value": { "fixedColor": "#FE2C55", "mode": "fixed" } }] },
          { "matcher": { "id": "byName", "options": "web" },      "properties": [{ "id": "color", "value": { "fixedColor": "#00CED1", "mode": "fixed" } }] },
          { "matcher": { "id": "byName", "options": "thread" },   "properties": [{ "id": "color", "value": { "fixedColor": "#A0A0A0", "mode": "fixed" } }] }
        ]
      },
      "targets": [
        {
          "datasource": { "type": "prometheus" },
          "expr": "rate(gateway_posts_by_platform_total{platform!~\"news_page|x|tt\"}[$__rate_interval]) * 3600",
          "legendFormat": "{{platform}}"
        }
      ]
    },

    {
      "id": 2,
      "title": "Request Rate (req/s)",
      "type": "timeseries",
      "gridPos": { "x": 16, "y": 13, "w": 8, "h": 4 },
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "custom": { "lineWidth": 2, "fillOpacity": 15, "gradientMode": "opacity" }
        }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus" },
          "expr": "rate(gateway_requests_total[5m])",
          "legendFormat": "{{endpoint}}"
        }
      ]
    },

    {
      "id": 3,
      "title": "Dead Letter Queue",
      "type": "stat",
      "gridPos": { "x": 16, "y": 9, "w": 4, "h": 4 },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background",
        "textMode": "auto",
        "graphMode": "area"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "#73BF69", "value": null },
              { "color": "#F2CC0C", "value": 10 },
              { "color": "#F2495C", "value": 50 }
            ]
          }
        }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus" },
          "expr": "gateway_dlq_size",
          "legendFormat": "DLQ"
        }
      ]
    },

    {
      "id": 14,
      "title": "Kafka Success Rate",
      "type": "gauge",
      "gridPos": { "x": 20, "y": 9, "w": 4, "h": 4 },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "orientation": "auto",
        "showThresholdLabels": false,
        "showThresholdMarkers": true
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "#F2495C", "value": null },
              { "color": "#F2CC0C", "value": 90 },
              { "color": "#73BF69", "value": 99 }
            ]
          }
        }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus" },
          "expr": "sum(rate(gateway_kafka_write_total{result=\"success\"}[5m])) / sum(rate(gateway_kafka_write_total[5m])) * 100",
          "legendFormat": "Success %"
        }
      ]
    },

    {
      "id": 19,
      "title": "Unknown Platform Rate",
      "type": "timeseries",
      "gridPos": { "x": 8, "y": 22, "w": 8, "h": 4 },
      "options": {
        "tooltip": { "mode": "single" }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "custom": { "lineWidth": 2, "fillOpacity": 20, "gradientMode": "opacity" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "#73BF69", "value": null },
              { "color": "#F2CC0C", "value": 10 },
              { "color": "#F2495C", "value": 100 }
            ]
          },
          "color": { "mode": "thresholds" }
        }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus" },
          "expr": "rate(gateway_unknown_platform_total[5m])",
          "legendFormat": "unknown platform req/s"
        }
      ]
    },


    {
      "id": 5,
      "title": "Request Latency Percentiles",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 26, "w": 12, "h": 8 },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": { "lineWidth": 2, "fillOpacity": 5 }
        },
        "overrides": [
          { "matcher": { "id": "byRegexp", "options": "p50.*" }, "properties": [{ "id": "color", "value": { "fixedColor": "#73BF69", "mode": "fixed" } }] },
          { "matcher": { "id": "byRegexp", "options": "p95.*" }, "properties": [{ "id": "color", "value": { "fixedColor": "#F2CC0C", "mode": "fixed" } }] },
          { "matcher": { "id": "byRegexp", "options": "p99.*" }, "properties": [{ "id": "color", "value": { "fixedColor": "#F2495C", "mode": "fixed" } }] }
        ]
      },
      "targets": [
        {
          "datasource": { "type": "prometheus" },
          "expr": "histogram_quantile(0.50, sum(rate(gateway_request_duration_seconds_bucket[5m])) by (le, endpoint))",
          "legendFormat": "p50 {{endpoint}}"
        },
        {
          "datasource": { "type": "prometheus" },
          "expr": "histogram_quantile(0.95, sum(rate(gateway_request_duration_seconds_bucket[5m])) by (le, endpoint))",
          "legendFormat": "p95 {{endpoint}}"
        },
        {
          "datasource": { "type": "prometheus" },
          "expr": "histogram_quantile(0.99, sum(rate(gateway_request_duration_seconds_bucket[5m])) by (le, endpoint))",
          "legendFormat": "p99 {{endpoint}}"
        }
      ]
    },

    {
      "id": 6,
      "title": "Kafka Write Rate by Topic",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 26, "w": 12, "h": 8 },
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "custom": { "lineWidth": 2, "fillOpacity": 15, "gradientMode": "opacity" }
        },
        "overrides": [
          { "matcher": { "id": "byRegexp", "options": ".*success.*" }, "properties": [{ "id": "color", "value": { "fixedColor": "#73BF69", "mode": "fixed" } }] },
          { "matcher": { "id": "byRegexp", "options": ".*error.*"   }, "properties": [{ "id": "color", "value": { "fixedColor": "#F2495C", "mode": "fixed" } }] },
          { "matcher": { "id": "byRegexp", "options": ".*failure.*" }, "properties": [{ "id": "color", "value": { "fixedColor": "#F2495C", "mode": "fixed" } }] }
        ]
      },
      "targets": [
        {
          "datasource": { "type": "prometheus" },
          "expr": "rate(gateway_kafka_write_total[5m])",
          "legendFormat": "{{topic}} [{{result}}]"
        }
      ]
    },

    {
      "id": 7,
      "title": "Số bài theo nền tảng (cửa sổ 5m)",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 34, "w": 12, "h": 8 },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "decimals": 0,
          "custom": { "lineWidth": 2, "fillOpacity": 10, "gradientMode": "opacity" }
        },
        "overrides": [
          { "matcher": { "id": "byName", "options": "youtube" },   "properties": [{ "id": "color", "value": { "fixedColor": "#FF0000", "mode": "fixed" } }] },
          { "matcher": { "id": "byName", "options": "facebook" },  "properties": [{ "id": "color", "value": { "fixedColor": "#1877F2", "mode": "fixed" } }] },
          { "matcher": { "id": "byName", "options": "tiktok" },    "properties": [{ "id": "color", "value": { "fixedColor": "#FE2C55", "mode": "fixed" } }] },
          { "matcher": { "id": "byName", "options": "telegram" },  "properties": [{ "id": "color", "value": { "fixedColor": "#26A5E4", "mode": "fixed" } }] },
          { "matcher": { "id": "byName", "options": "web" },       "properties": [{ "id": "color", "value": { "fixedColor": "#00CED1", "mode": "fixed" } }] },
          { "matcher": { "id": "byName", "options": "x" },         "properties": [{ "id": "color", "value": { "fixedColor": "#A0A0A0", "mode": "fixed" } }] }
        ]
      },
      "targets": [
        {
          "datasource": { "type": "prometheus" },
          "expr": "increase(gateway_posts_by_platform_total{platform!=\"news_page\"}[5m])",
          "legendFormat": "{{platform}}"
        }
      ]
    },

    {
      "id": 8,
      "title": "Go Goroutines",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 34, "w": 6, "h": 8 },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": { "lineWidth": 2, "fillOpacity": 15, "gradientMode": "opacity" },
          "color": { "mode": "fixed", "fixedColor": "#73BF69" }
        }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus" },
          "expr": "go_goroutines{job=\"gateway\"}",
          "legendFormat": "goroutines"
        }
      ]
    },

    {
      "id": 9,
      "title": "Go Heap Memory",
      "type": "timeseries",
      "gridPos": { "x": 18, "y": 34, "w": 6, "h": 8 },
      "fieldConfig": {
        "defaults": {
          "unit": "bytes",
          "custom": { "lineWidth": 2, "fillOpacity": 10, "gradientMode": "opacity" }
        },
        "overrides": [
          { "matcher": { "id": "byName", "options": "heap alloc" }, "properties": [{ "id": "color", "value": { "fixedColor": "#5794F2", "mode": "fixed" } }] },
          { "matcher": { "id": "byName", "options": "heap sys" },   "properties": [{ "id": "color", "value": { "fixedColor": "#F2CC0C", "mode": "fixed" } }] }
        ]
      },
      "targets": [
        {
          "datasource": { "type": "prometheus" },
          "expr": "go_memstats_heap_alloc_bytes{job=\"gateway\"}",
          "legendFormat": "heap alloc"
        },
        {
          "datasource": { "type": "prometheus" },
          "expr": "go_memstats_heap_sys_bytes{job=\"gateway\"}",
          "legendFormat": "heap sys"
        }
      ]
    },

    {
      "id": 15,
      "title": "HTTP Error Rate (4xx / 5xx)",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 42, "w": 12, "h": 8 },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0,
          "max": 1,
          "custom": { "lineWidth": 2, "fillOpacity": 20, "gradientMode": "opacity" }
        },
        "overrides": [
          { "matcher": { "id": "byName", "options": "4xx rate" }, "properties": [{ "id": "color", "value": { "fixedColor": "#F2CC0C", "mode": "fixed" } }] },
          { "matcher": { "id": "byName", "options": "5xx rate" }, "properties": [{ "id": "color", "value": { "fixedColor": "#F2495C", "mode": "fixed" } }] }
        ]
      },
      "targets": [
        {
          "datasource": { "type": "prometheus" },
          "expr": "sum(rate(gateway_http_errors_total{code=~\"4..\"}[5m])) / sum(rate(gateway_requests_total[5m]))",
          "legendFormat": "4xx rate"
        },
        {
          "datasource": { "type": "prometheus" },
          "expr": "sum(rate(gateway_http_errors_total{code=~\"5..\"}[5m])) / sum(rate(gateway_requests_total[5m]))",
          "legendFormat": "5xx rate"
        }
      ]
    },

    {
      "id": 10,
      "title": "Request Duration Heatmap",
      "type": "heatmap",
      "gridPos": { "x": 12, "y": 42, "w": 12, "h": 8 },
      "options": {
        "calculate": false,
        "yAxis": { "unit": "s" },
        "color": { "scheme": "Oranges" }
      },
      "fieldConfig": {
        "defaults": { "unit": "s" }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus" },
          "expr": "sum(rate(gateway_request_duration_seconds_bucket[5m])) by (le)",
          "legendFormat": "{{le}}",
          "format": "heatmap"
        }
      ]
    },

    {
      "id": 300,
      "title": "Kafka",
      "type": "row",
      "gridPos": { "x": 0, "y": 50, "w": 24, "h": 1 },
      "collapsed": false
    },

    {
      "id": 11,
      "title": "Kafka Consumer Lag by Topic",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 51, "w": 12, "h": 8 },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": { "lineWidth": 2, "fillOpacity": 10, "gradientMode": "opacity" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "#73BF69", "value": null },
              { "color": "#F2CC0C", "value": 1000 },
              { "color": "#F2495C", "value": 10000 }
            ]
          }
        }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus" },
          "expr": "sum by (topic) (kafka_consumergroup_lag)",
          "legendFormat": "{{topic}}"
        }
      ]
    },

    {
      "id": 12,
      "title": "Kafka Consumer Lag by Group",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 51, "w": 12, "h": 8 },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": { "lineWidth": 2, "fillOpacity": 10, "gradientMode": "opacity" }
        }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus" },
          "expr": "sum by (consumergroup) (kafka_consumergroup_lag)",
          "legendFormat": "{{consumergroup}}"
        }
      ]
    },

    {
      "id": 13,
      "title": "Kafka Total Lag",
      "type": "stat",
      "gridPos": { "x": 0, "y": 59, "w": 8, "h": 4 },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background",
        "textMode": "auto",
        "graphMode": "area"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "#73BF69", "value": null },
              { "color": "#F2CC0C", "value": 1000 },
              { "color": "#F2495C", "value": 10000 }
            ]
          }
        }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus" },
          "expr": "sum(kafka_consumergroup_lag)",
          "legendFormat": "Total Lag"
        }
      ]
    },

    {
      "id": 16,
      "title": "Kafka Write Errors Today",
      "type": "stat",
      "gridPos": { "x": 8, "y": 59, "w": 8, "h": 4 },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background",
        "textMode": "value_and_name",
        "orientation": "vertical"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "#73BF69", "value": null },
              { "color": "#F2CC0C", "value": 1 },
              { "color": "#F2495C", "value": 100 }
            ]
          }
        }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus" },
          "expr": "increase(gateway_kafka_write_total{result!=\"success\"}[$__range])",
          "legendFormat": "{{topic}}",
          "instant": true
        }
      ]
    },

    {
      "id": 17,
      "title": "Kafka Write Success vs Error",
      "type": "timeseries",
      "gridPos": { "x": 16, "y": 59, "w": 8, "h": 8 },
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "custom": { "lineWidth": 2, "fillOpacity": 15, "gradientMode": "opacity" }
        },
        "overrides": [
          { "matcher": { "id": "byName", "options": "success" }, "properties": [{ "id": "color", "value": { "fixedColor": "#73BF69", "mode": "fixed" } }] },
          { "matcher": { "id": "byName", "options": "error" },   "properties": [{ "id": "color", "value": { "fixedColor": "#F2495C", "mode": "fixed" } }] }
        ]
      },
      "targets": [
        {
          "datasource": { "type": "prometheus" },
          "expr": "sum(rate(gateway_kafka_write_total{result=\"success\"}[5m]))",
          "legendFormat": "success"
        },
        {
          "datasource": { "type": "prometheus" },
          "expr": "sum(rate(gateway_kafka_write_total{result!=\"success\"}[5m]))",
          "legendFormat": "error"
        }
      ]
    },

    {
      "id": 400,
      "title": "MongoDB",
      "type": "row",
      "gridPos": { "x": 0, "y": 67, "w": 24, "h": 1 },
      "collapsed": false
    },

    {
      "id": 401,
      "title": "MongoDB Status",
      "type": "stat",
      "gridPos": { "x": 0, "y": 68, "w": 4, "h": 4 },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background",
        "textMode": "auto",
        "graphMode": "none",
        "orientation": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "mappings": [
            { "type": "value", "options": { "0": { "text": "DOWN", "color": "#F2495C" }, "1": { "text": "UP", "color": "#73BF69" } } }
          ],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "#F2495C", "value": null },
              { "color": "#73BF69", "value": 1 }
            ]
          }
        }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus" },
          "expr": "mongodb_up",
          "legendFormat": "MongoDB"
        }
      ]
    },

    {
      "id": 402,
      "title": "Current Connections",
      "type": "stat",
      "gridPos": { "x": 4, "y": 68, "w": 5, "h": 4 },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background",
        "textMode": "auto",
        "graphMode": "area"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "#73BF69", "value": null },
              { "color": "#F2CC0C", "value": 200 },
              { "color": "#F2495C", "value": 500 }
            ]
          }
        }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus" },
          "expr": "mongodb_connections{state=\"current\"}",
          "legendFormat": "current"
        }
      ]
    },

    {
      "id": 403,
      "title": "Available Connections",
      "type": "stat",
      "gridPos": { "x": 9, "y": 68, "w": 5, "h": 4 },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "value",
        "textMode": "auto",
        "graphMode": "none"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": { "mode": "fixed", "fixedColor": "#73BF69" }
        }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus" },
          "expr": "mongodb_connections{state=\"available\"}",
          "legendFormat": "available"
        }
      ]
    },

    {
      "id": 404,
      "title": "Resident Memory",
      "type": "stat",
      "gridPos": { "x": 14, "y": 68, "w": 5, "h": 4 },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background",
        "textMode": "auto",
        "graphMode": "area"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "decmbytes",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "#73BF69", "value": null },
              { "color": "#F2CC0C", "value": 1024 },
              { "color": "#F2495C", "value": 2048 }
            ]
          }
        }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus" },
          "expr": "mongodb_memory{type=\"resident\"}",
          "legendFormat": "resident"
        }
      ]
    },

    {
      "id": 405,
      "title": "Virtual Memory",
      "type": "stat",
      "gridPos": { "x": 19, "y": 68, "w": 5, "h": 4 },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "value",
        "textMode": "auto",
        "graphMode": "none"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "decmbytes",
          "color": { "mode": "fixed", "fixedColor": "#5794F2" }
        }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus" },
          "expr": "mongodb_memory{type=\"virtual\"}",
          "legendFormat": "virtual"
        }
      ]
    },

    {
      "id": 406,
      "title": "Operations per Second",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 72, "w": 12, "h": 8 },
      "fieldConfig": {
        "defaults": {
          "unit": "ops",
          "custom": { "lineWidth": 2, "fillOpacity": 10, "gradientMode": "opacity" }
        },
        "overrides": [
          { "matcher": { "id": "byName", "options": "insert" },  "properties": [{ "id": "color", "value": { "fixedColor": "#73BF69", "mode": "fixed" } }] },
          { "matcher": { "id": "byName", "options": "query" },   "properties": [{ "id": "color", "value": { "fixedColor": "#5794F2", "mode": "fixed" } }] },
          { "matcher": { "id": "byName", "options": "update" },  "properties": [{ "id": "color", "value": { "fixedColor": "#F2CC0C", "mode": "fixed" } }] },
          { "matcher": { "id": "byName", "options": "delete" },  "properties": [{ "id": "color", "value": { "fixedColor": "#F2495C", "mode": "fixed" } }] },
          { "matcher": { "id": "byName", "options": "command" }, "properties": [{ "id": "color", "value": { "fixedColor": "#A0A0A0", "mode": "fixed" } }] }
        ]
      },
      "targets": [
        {
          "datasource": { "type": "prometheus" },
          "expr": "rate(mongodb_op_counters_total[5m])",
          "legendFormat": "{{type}}"
        }
      ]
    },

    {
      "id": 407,
      "title": "Connections Over Time",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 72, "w": 12, "h": 8 },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": { "lineWidth": 2, "fillOpacity": 15, "gradientMode": "opacity" }
        },
        "overrides": [
          { "matcher": { "id": "byName", "options": "current" },   "properties": [{ "id": "color", "value": { "fixedColor": "#5794F2", "mode": "fixed" } }] },
          { "matcher": { "id": "byName", "options": "available" }, "properties": [{ "id": "color", "value": { "fixedColor": "#73BF69", "mode": "fixed" } }] }
        ]
      },
      "targets": [
        {
          "datasource": { "type": "prometheus" },
          "expr": "mongodb_connections{state=\"current\"}",
          "legendFormat": "current"
        },
        {
          "datasource": { "type": "prometheus" },
          "expr": "mongodb_connections{state=\"available\"}",
          "legendFormat": "available"
        }
      ]
    },

    {
      "id": 408,
      "title": "Memory Usage Over Time",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 80, "w": 12, "h": 8 },
      "fieldConfig": {
        "defaults": {
          "unit": "decmbytes",
          "custom": { "lineWidth": 2, "fillOpacity": 10, "gradientMode": "opacity" }
        },
        "overrides": [
          { "matcher": { "id": "byName", "options": "resident" }, "properties": [{ "id": "color", "value": { "fixedColor": "#F2CC0C", "mode": "fixed" } }] },
          { "matcher": { "id": "byName", "options": "virtual" },  "properties": [{ "id": "color", "value": { "fixedColor": "#5794F2", "mode": "fixed" } }] }
        ]
      },
      "targets": [
        {
          "datasource": { "type": "prometheus" },
          "expr": "mongodb_memory{type=\"resident\"}",
          "legendFormat": "resident"
        },
        {
          "datasource": { "type": "prometheus" },
          "expr": "mongodb_memory{type=\"virtual\"}",
          "legendFormat": "virtual"
        }
      ]
    },

    {
      "id": 409,
      "title": "Network In/Out",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 80, "w": 12, "h": 8 },
      "fieldConfig": {
        "defaults": {
          "unit": "Bps",
          "custom": { "lineWidth": 2, "fillOpacity": 10, "gradientMode": "opacity" }
        },
        "overrides": [
          { "matcher": { "id": "byName", "options": "bytes_in" },  "properties": [{ "id": "color", "value": { "fixedColor": "#73BF69", "mode": "fixed" } }] },
          { "matcher": { "id": "byName", "options": "bytes_out" }, "properties": [{ "id": "color", "value": { "fixedColor": "#5794F2", "mode": "fixed" } }] }
        ]
      },
      "targets": [
        {
          "datasource": { "type": "prometheus" },
          "expr": "rate(mongodb_network_bytes_total{state=\"bytes_in\"}[5m])",
          "legendFormat": "bytes_in"
        },
        {
          "datasource": { "type": "prometheus" },
          "expr": "rate(mongodb_network_bytes_total{state=\"bytes_out\"}[5m])",
          "legendFormat": "bytes_out"
        }
      ]
    }

  ]
}
