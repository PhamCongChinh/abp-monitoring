{
  "uid": "health-overview",
  "title": "Health / Uptime",
  "tags": ["health", "ops"],
  "timezone": "browser",
  "schemaVersion": 39,
  "refresh": "30s",
  "time": { "from": "now-3h", "to": "now" },
  "panels": [

    {
      "id": 1,
      "title": "Service Status",
      "type": "row",
      "gridPos": { "x": 0, "y": 0, "w": 24, "h": 1 },
      "collapsed": false
    },

    {
      "id": 2, "title": "Gateway",
      "type": "stat", "gridPos": { "x": 0, "y": 1, "w": 4, "h": 4 },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background", "textMode": "auto", "graphMode": "none" },
      "fieldConfig": {
        "defaults": {
          "mappings": [{ "type": "value", "options": { "0": { "text": "DOWN", "color": "#F2495C", "index": 0 }, "1": { "text": "UP", "color": "#73BF69", "index": 1 } } }],
          "thresholds": { "mode": "absolute", "steps": [{ "color": "#F2495C", "value": null }, { "color": "#73BF69", "value": 1 }] },
          "color": { "mode": "thresholds" }
        }
      },
      "targets": [{ "datasource": { "type": "prometheus" }, "expr": "up{job=\"gateway\"}", "instant": true }]
    },

    {
      "id": 3, "title": "Kafka",
      "type": "stat", "gridPos": { "x": 4, "y": 1, "w": 4, "h": 4 },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background", "textMode": "auto", "graphMode": "none" },
      "fieldConfig": {
        "defaults": {
          "mappings": [{ "type": "value", "options": { "0": { "text": "DOWN", "color": "#F2495C", "index": 0 }, "1": { "text": "UP", "color": "#73BF69", "index": 1 } } }],
          "thresholds": { "mode": "absolute", "steps": [{ "color": "#F2495C", "value": null }, { "color": "#73BF69", "value": 1 }] },
          "color": { "mode": "thresholds" }
        }
      },
      "targets": [{ "datasource": { "type": "prometheus" }, "expr": "up{job=\"kafka-exporter\"}", "instant": true }]
    },

    {
      "id": 4, "title": "MongoDB",
      "type": "stat", "gridPos": { "x": 8, "y": 1, "w": 4, "h": 4 },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background", "textMode": "auto", "graphMode": "none" },
      "fieldConfig": {
        "defaults": {
          "mappings": [{ "type": "value", "options": { "0": { "text": "DOWN", "color": "#F2495C", "index": 0 }, "1": { "text": "UP", "color": "#73BF69", "index": 1 } } }],
          "thresholds": { "mode": "absolute", "steps": [{ "color": "#F2495C", "value": null }, { "color": "#73BF69", "value": 1 }] },
          "color": { "mode": "thresholds" }
        }
      },
      "targets": [{ "datasource": { "type": "prometheus" }, "expr": "mongodb_up", "instant": true }]
    },

    {
      "id": 5, "title": "Redis",
      "type": "stat", "gridPos": { "x": 12, "y": 1, "w": 4, "h": 4 },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background", "textMode": "auto", "graphMode": "none" },
      "fieldConfig": {
        "defaults": {
          "mappings": [{ "type": "value", "options": { "0": { "text": "DOWN", "color": "#F2495C", "index": 0 }, "1": { "text": "UP", "color": "#73BF69", "index": 1 } } }],
          "thresholds": { "mode": "absolute", "steps": [{ "color": "#F2495C", "value": null }, { "color": "#73BF69", "value": 1 }] },
          "color": { "mode": "thresholds" }
        }
      },
      "targets": [{ "datasource": { "type": "prometheus" }, "expr": "up{job=\"redis\"}", "instant": true }]
    },

    {
      "id": 6, "title": "Alertmanager",
      "type": "stat", "gridPos": { "x": 16, "y": 1, "w": 4, "h": 4 },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background", "textMode": "auto", "graphMode": "none" },
      "fieldConfig": {
        "defaults": {
          "mappings": [{ "type": "value", "options": { "0": { "text": "DOWN", "color": "#F2495C", "index": 0 }, "1": { "text": "UP", "color": "#73BF69", "index": 1 } } }],
          "thresholds": { "mode": "absolute", "steps": [{ "color": "#F2495C", "value": null }, { "color": "#73BF69", "value": 1 }] },
          "color": { "mode": "thresholds" }
        }
      },
      "targets": [{ "datasource": { "type": "prometheus" }, "expr": "up{job=\"alertmanager\"}", "instant": true }]
    },

    {
      "id": 7, "title": "Node Exporter",
      "type": "stat", "gridPos": { "x": 20, "y": 1, "w": 4, "h": 4 },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background", "textMode": "auto", "graphMode": "none" },
      "fieldConfig": {
        "defaults": {
          "mappings": [{ "type": "value", "options": { "0": { "text": "DOWN", "color": "#F2495C", "index": 0 }, "1": { "text": "UP", "color": "#73BF69", "index": 1 } } }],
          "thresholds": { "mode": "absolute", "steps": [{ "color": "#F2495C", "value": null }, { "color": "#73BF69", "value": 1 }] },
          "color": { "mode": "thresholds" }
        }
      },
      "targets": [{ "datasource": { "type": "prometheus" }, "expr": "up{job=\"node-exporter-local\"}", "instant": true }]
    },

    {
      "id": 10,
      "title": "Infrastructure",
      "type": "row",
      "gridPos": { "x": 0, "y": 5, "w": 24, "h": 1 },
      "collapsed": false
    },

    {
      "id": 11,
      "title": "OOM Kills (1h)",
      "type": "stat",
      "gridPos": { "x": 0, "y": 6, "w": 6, "h": 4 },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background", "textMode": "auto", "graphMode": "none" },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "#73BF69", "value": null },
              { "color": "#F2495C", "value": 1 }
            ]
          },
          "color": { "mode": "thresholds" }
        }
      },
      "targets": [{ "datasource": { "type": "prometheus" }, "expr": "increase(node_vmstat_oom_kill[1h])", "legendFormat": "OOM kills", "instant": true }]
    },

    {
      "id": 12,
      "title": "Disk Used %",
      "type": "gauge",
      "gridPos": { "x": 6, "y": 6, "w": 6, "h": 4 },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "orientation": "auto", "showThresholdLabels": false, "showThresholdMarkers": true },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0, "max": 100,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "#73BF69", "value": null },
              { "color": "#F2CC0C", "value": 75 },
              { "color": "#F2495C", "value": 90 }
            ]
          }
        }
      },
      "targets": [{
        "datasource": { "type": "prometheus" },
        "expr": "(1 - node_filesystem_avail_bytes{mountpoint=\"/\",fstype!~\"tmpfs\"} / node_filesystem_size_bytes{mountpoint=\"/\",fstype!~\"tmpfs\"}) * 100",
        "legendFormat": "/ disk",
        "instant": true
      }]
    },

    {
      "id": 13,
      "title": "RAM Available",
      "type": "gauge",
      "gridPos": { "x": 12, "y": 6, "w": 6, "h": 4 },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "orientation": "auto", "showThresholdLabels": false, "showThresholdMarkers": true },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0, "max": 100,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "#F2495C", "value": null },
              { "color": "#F2CC0C", "value": 15 },
              { "color": "#73BF69", "value": 30 }
            ]
          }
        }
      },
      "targets": [{
        "datasource": { "type": "prometheus" },
        "expr": "(node_memory_MemAvailable_bytes / node_memory_MemTotal_bytes) * 100",
        "legendFormat": "RAM available",
        "instant": true
      }]
    },

    {
      "id": 14,
      "title": "CPU Usage",
      "type": "gauge",
      "gridPos": { "x": 18, "y": 6, "w": 6, "h": 4 },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "orientation": "auto", "showThresholdLabels": false, "showThresholdMarkers": true },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0, "max": 100,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "#73BF69", "value": null },
              { "color": "#F2CC0C", "value": 70 },
              { "color": "#F2495C", "value": 85 }
            ]
          }
        }
      },
      "targets": [{
        "datasource": { "type": "prometheus" },
        "expr": "100 - (avg(rate(node_cpu_seconds_total{mode=\"idle\"}[5m])) * 100)",
        "legendFormat": "CPU %",
        "instant": true
      }]
    },

    {
      "id": 20,
      "title": "Container Resources",
      "type": "row",
      "gridPos": { "x": 0, "y": 10, "w": 24, "h": 1 },
      "collapsed": false
    },

    {
      "id": 21,
      "title": "CPU per Container",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 11, "w": 12, "h": 8 },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "custom": { "lineWidth": 2, "fillOpacity": 10, "gradientMode": "opacity" }
        }
      },
      "targets": [{
        "datasource": { "type": "prometheus" },
        "expr": "sum by (name) (rate(container_cpu_usage_seconds_total{name!=\"\"}[5m]))",
        "legendFormat": "{{name}}"
      }]
    },

    {
      "id": 22,
      "title": "RAM per Container",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 11, "w": 12, "h": 8 },
      "fieldConfig": {
        "defaults": {
          "unit": "bytes",
          "custom": { "lineWidth": 2, "fillOpacity": 10, "gradientMode": "opacity" }
        }
      },
      "targets": [{
        "datasource": { "type": "prometheus" },
        "expr": "container_memory_rss{name!=\"\"}",
        "legendFormat": "{{name}}"
      }]
    },

    {
      "id": 30,
      "title": "Disk & OOM Trend",
      "type": "row",
      "gridPos": { "x": 0, "y": 19, "w": 24, "h": 1 },
      "collapsed": false
    },

    {
      "id": 31,
      "title": "Disk Available (GB)",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 20, "w": 16, "h": 8 },
      "fieldConfig": {
        "defaults": {
          "unit": "decgbytes",
          "custom": { "lineWidth": 2, "fillOpacity": 15, "gradientMode": "opacity" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "#73BF69", "value": null },
              { "color": "#F2CC0C", "value": 20 },
              { "color": "#F2495C", "value": 5 }
            ]
          }
        }
      },
      "targets": [{
        "datasource": { "type": "prometheus" },
        "expr": "node_filesystem_avail_bytes{mountpoint=\"/\",fstype!~\"tmpfs\"} / 1e9",
        "legendFormat": "/ available"
      }]
    },

    {
      "id": 32,
      "title": "OOM Kills",
      "type": "timeseries",
      "gridPos": { "x": 16, "y": 20, "w": 8, "h": 8 },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": { "lineWidth": 2, "fillOpacity": 30, "gradientMode": "opacity" },
          "color": { "mode": "fixed", "fixedColor": "#F2495C" }
        }
      },
      "targets": [{
        "datasource": { "type": "prometheus" },
        "expr": "increase(node_vmstat_oom_kill[5m])",
        "legendFormat": "OOM kills"
      }]
    }

  ]
}
